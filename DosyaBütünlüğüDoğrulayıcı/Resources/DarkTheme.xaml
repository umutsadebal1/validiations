<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Koyu Tema Renkleri (Modern, Profesyonel) -->
    <Color x:Key="BackgroundColor">#252526</Color>
    <Color x:Key="ForegroundColor">#e0e0e0</Color>
    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="ErrorColor">#F48771</Color>
    <Color x:Key="BorderColor">#3e3e42</Color>
    <Color x:Key="HoverColor">#2d2d30</Color>
    <Color x:Key="SurfaceColor">#1e1e1e</Color>
    
    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#e0e0e0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F48771"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3e3e42"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#2d2d30"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="SidebarButtonBackgroundBrush" Color="#3e3e42"/>
    <SolidColorBrush x:Key="SidebarButtonForegroundBrush" Color="#ffffff"/>
    
    <!-- Global Styles -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="white"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#4A4A4A"/>
                <Setter Property="Foreground" Value="#D0D0D0"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1084d7"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#3a3a3e"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="#007ACC"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="CaretBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#3a3a3e"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="#007ACC"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#2d2d30"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="Padding" Value="15,5"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ListView">
        <Setter Property="Background" Value="#252526"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

</ResourceDictionary>
