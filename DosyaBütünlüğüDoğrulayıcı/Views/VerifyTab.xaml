<UserControl x:Class="DosyaBütünlüğüDoğrulayıcı.Views.VerifyTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,30">
            <TextBlock Text="✓ Hash Verification" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            <TextBlock Text="Compare file hash with stored value..." FontSize="12" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
            
            <TextBlock Text="1. Select File" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" Padding="10" Text="No file selected..." IsReadOnly="True"/>
                    <Button x:Name="BrowseButton" Grid.Column="1" Content="📁 BROWSE" Margin="10,0,0,0" Click="BrowseButton_Click" Padding="12,8" Width="120"/>
                </Grid>
            </Border>
            
            <TextBlock Text="2. Select Algorithm" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <ComboBox x:Name="AlgorithmComboBox" Height="38">
                    <ComboBoxItem Content="SHA256" IsSelected="True"/>
                    <ComboBoxItem Content="SHA512"/>
                    <ComboBoxItem Content="MD5"/>
                    <ComboBoxItem Content="SHA1"/>
                </ComboBox>
            </Border>
            
            <TextBlock Text="3. Enter Original Hash" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBox x:Name="OldHashTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="10" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📋 Paste" Click="PasteButton_Click" Padding="10,8" Width="120" Margin="0,0,10,0"/>
                        <Button Content="📥 Load from DB" Click="LoadFromDatabaseButton_Click" Padding="10,8" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <TextBlock Text="4. Compare" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button x:Name="CompareButton" Content="🔍 COMPARE" Click="CompareButton_Click" Padding="15,10" Width="150" Margin="0,0,10,0"/>
                <Button x:Name="ClearButton" Content="🔄 CLEAR" Click="ClearButton_Click" Padding="15,10" Width="150"/>
            </StackPanel>
            
            <!-- Progress -->
            <ProgressBar x:Name="ProgressBar" Height="6" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource AccentBrush}" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" Margin="0,0,0,10"/>
            <TextBlock x:Name="ProgressTextBlock" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="11" Visibility="Collapsed" Margin="0,0,0,10"/>
            
            <!-- Result -->
            <Border x:Name="ResultBorder" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Background="{DynamicResource SurfaceBrush}" Visibility="Collapsed" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="ResultStatusIcon" Text="" FontSize="24" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultStatusText" Text="" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ResultFileName" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultFileSize" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultAlgorithm" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultTime" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultDateTime" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ResultOldHash" Text="" FontFamily="Consolas" FontSize="9" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ResultNewHash" Text="" FontFamily="Consolas" FontSize="9" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="UpdateDatabaseButton" Content="💾 UPDATE DATABASE" Click="UpdateDatabaseButton_Click" Padding="10,5" Width="160" Margin="0,0,10,0" Visibility="Collapsed"/>
                        <Button Content="📋 COPY HASH" Click="CopyHashButton_Click" Padding="10,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Error -->
            <Border x:Name="ErrorBorder" CornerRadius="8" BorderBrush="#ff4455" BorderThickness="1" Padding="15" Background="{DynamicResource SurfaceBrush}" Visibility="Collapsed" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚠️ ERROR" FontSize="14" FontWeight="Bold" Foreground="#ff4455" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ErrorMessageTextBlock" Text="" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" FontSize="12"/>
                </StackPanel>
            </Border>
            
            <!-- Info -->
            <TextBlock x:Name="HashInfoTextBlock" Text="" Foreground="{DynamicResource ForegroundBrush}" FontSize="11" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>