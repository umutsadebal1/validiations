<UserControl x:Class="DosyaBütünlüğüDoğrulayıcı.Views.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,20">
            
            <!-- LOGO -->
            <Image Source="pack://application:,,,/Assets/Logos/app_logo.png"
                   Height="200"
                   Width="200"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,40"/>
            
            <!-- BAŞLIK -->
            <TextBlock Text="Dashboard" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,30"/>

            <!-- HIZLI İŞLEMLER SECTION -->
            <TextBlock Text="Quick Actions" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Hash File -->
                <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="8" MinHeight="100"
                        Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Button Click="BtnQuickHash_Click" Foreground="{DynamicResource ForegroundBrush}" Padding="15">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📄" FontSize="40" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Hash File" FontSize="13" TextAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Hash Folder -->
                <Border Grid.Column="1" Margin="10,0,10,0" CornerRadius="8" MinHeight="100"
                        Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Button Click="BtnQuickFolder_Click" Foreground="{DynamicResource ForegroundBrush}" Padding="15">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="40" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Hash Folder" FontSize="13" TextAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Verify Hash -->
                <Border Grid.Column="2" Margin="10,0,10,0" CornerRadius="8" MinHeight="100"
                        Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Button Click="BtnQuickVerify_Click" Foreground="{DynamicResource ForegroundBrush}" Padding="15">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="✓" FontSize="40" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Verify Hash" FontSize="13" TextAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Settings -->
                <Border Grid.Column="3" Margin="10,0,0,0" CornerRadius="8" MinHeight="100"
                        Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Button Click="BtnQuickSettings_Click" Foreground="{DynamicResource ForegroundBrush}" Padding="15">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⚙️" FontSize="40" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Settings" FontSize="13" TextAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>

            <!-- İSTATİSTİKLER SECTION -->
            <TextBlock Text="Statistics" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Toplam Dosya -->
                <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="8" 
                        Background="#2d2d30" BorderBrush="#444447" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Files" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                        <TextBlock Name="StatTotalFiles" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00D4FF"/>
                    </StackPanel>
                </Border>

                <!-- İşlenen Dosyalar -->
                <Border Grid.Column="1" Margin="10,0,10,0" CornerRadius="8" 
                        Background="#2d2d30" BorderBrush="#444447" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Processed Files" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                        <TextBlock Name="StatProcessedFiles" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00D4FF"/>
                    </StackPanel>
                </Border>

                <!-- Verified -->
                <Border Grid.Column="2" Margin="10,0,10,0" CornerRadius="8" 
                        Background="#2d2d30" BorderBrush="#444447" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Verified" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                        <TextBlock Name="StatVerified" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00D4FF"/>
                    </StackPanel>
                </Border>

                <!-- Mismatched -->
                <Border Grid.Column="3" Margin="10,0,0,0" CornerRadius="8" 
                        Background="#2d2d30" BorderBrush="#444447" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Mismatched" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                        <TextBlock Name="StatMismatched" Text="0" FontSize="24" FontWeight="Bold" Foreground="#FF4455"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- RECENT ACTIVITY SECTION -->
            <TextBlock Text="Recent Activity" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,15"/>

            <Border CornerRadius="8" Background="#2d2d30" BorderBrush="#444447" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,20">
                <ListBox Name="RecentActivityList" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="White"
                         Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="#00D4FF"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#999999"/>
                                <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="#666666"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
