<UserControl x:Class="DosyaBütünlüğüDoğrulayıcı.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2F2F34"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2F2F34"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,30" MaxWidth="600">
            <TextBlock Text="⚙️ Application Settings" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="#2F2F34" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Theme" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Name="TxtCurrentTheme" Text="Current Theme: Dark" FontSize="11" Margin="0,0,0,10" Opacity="0.9"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Name="BtnSetDarkTheme" Content="🌙 Dark" Click="BtnSetDarkTheme_Click" Padding="12,8" Width="120" Margin="0,0,10,0"/>
                        <Button Name="BtnSetLightTheme" Content="☀️ Light" Click="BtnSetLightTheme_Click" Padding="12,8" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="#2F2F34" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <CheckBox Name="ChkStartupCheck" Content="⚡ Launch at startup" FontSize="12" IsChecked="False" Checked="ChkStartupCheck_Checked" Unchecked="ChkStartupCheck_Unchecked"/>
            </Border>
            
            <TextBlock Text="Hash History" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="#2F2F34" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Click below to clear all history." FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10" Opacity="0.9"/>
                    <Button Name="BtnClearHistory" Content="🗑️ CLEAR HISTORY" Click="BtnClearHistory_Click" Padding="15,10" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="Data Export" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="#2F2F34" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Select Format:" FontSize="12" Margin="0,0,0,10"/>
                    <ComboBox Name="ComboExportFormat" Padding="10" Height="38" Margin="0,0,0,10">
                        <ComboBoxItem Content="CSV" IsSelected="True"/>
                        <ComboBoxItem Content="JSON"/>
                    </ComboBox>
                    <Button Name="BtnExport" Content="📤 EXPORT" Click="BtnExport_Click" Padding="15,10" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="v1.0 - File Integrity Verifier" TextAlignment="Center" FontSize="11" Margin="0,30,0,0" Opacity="0.8"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
