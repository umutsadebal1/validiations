<UserControl x:Class="DosyaBütünlüğüDoğrulayıcı.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,30" MaxWidth="600">
            <TextBlock Text="⚙️ Application Settings" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="#3a3a3e" BorderBrush="#007ACC" BorderThickness="2" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Theme" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Text="Use the theme toggle button in the main window (🌙 button)." Foreground="{DynamicResource ForegroundBrush}" FontSize="11" TextWrapping="Wrap" Opacity="0.8"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <CheckBox Name="ChkStartupCheck" Content="⚡ Launch at startup" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" IsChecked="False" Checked="ChkStartupCheck_Checked" Unchecked="ChkStartupCheck_Unchecked"/>
            </Border>
            
            <TextBlock Text="Hash History" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Click below to clear all history." Foreground="{DynamicResource ForegroundBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10" Opacity="0.8"/>
                    <Button Name="BtnClearHistory" Content="🗑️ CLEAR HISTORY" Click="BtnClearHistory_Click" Padding="15,10" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="Data Export" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,12"/>
            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Select Format:" Foreground="{DynamicResource ForegroundBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <ComboBox Name="ComboExportFormat" Padding="10" Height="38" Margin="0,0,0,10">
                        <ComboBoxItem Content="CSV" IsSelected="True"/>
                        <ComboBoxItem Content="JSON"/>
                    </ComboBox>
                    <Button Name="BtnExport" Content="📤 EXPORT" Click="BtnExport_Click" Padding="15,10" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="v1.0 - File Integrity Verifier" Foreground="{DynamicResource ForegroundBrush}" TextAlignment="Center" FontSize="11" Margin="0,30,0,0" Opacity="0.6"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
