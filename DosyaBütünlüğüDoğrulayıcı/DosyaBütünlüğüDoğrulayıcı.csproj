<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>DosyaBütünlüğüDoğrulayıcı</RootNamespace>
    <AssemblyName>DosyaBütünlüğüDoğrulayıcı</AssemblyName>
    <UseWPF>true</UseWPF>
    <Version>1.0.0</Version>
    <Authors>VALID Development</Authors>
    <Description>Dosya Bütünlüğü Doğrulayıcı - WPF Desktop Application</Description>
    <ApplicationIcon>Assets\Icons\app_icon.ico</ApplicationIcon>
    <PackageIcon></PackageIcon>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.SQLite" Version="1.0.118.0" />
    <PackageReference Include="System.ComponentModel.TypeConverter" Version="4.3.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\DarkTheme.xaml" />
    <Resource Include="Resources\LightTheme.xaml" />
    <Resource Include="Assets\Icons\app_icon.ico" />
    <Resource Include="Assets\Logos\app_logo.png" />
  </ItemGroup>

</Project>
