<Window x:Class="DosyaBütünlüğüDoğrulayıcı.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DosyaBütünlüğüDoğrulayıcı.Views"
        Title="File Integrity Verifier v1.0"
        Height="600"
        Width="900"
        Icon="Assets/Icons/app_icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="#007ACC" BorderThickness="0,0,1,0">
            <StackPanel Margin="0" VerticalAlignment="Stretch">
                
                <!-- Logo Section -->
                <Border Background="#007ACC" Padding="15,20">
                    <StackPanel>
                        <TextBlock Text="🔐 VALIDC#" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="v1.0" 
                                   FontSize="9" 
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <!-- Navigation Buttons -->
                <Button Name="BtnDashboard" 
                        Content="📊 Dashboard" 
                        Click="BtnDashboard_Click"
                        Margin="8,8,8,4"
                        Padding="10,12"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Name="BtnMainTab" 
                        Content="📄 Main Page" 
                        Click="BtnMainTab_Click"
                        Margin="8,4,8,4"
                        Padding="10,12"
                        Background="#3e3e42"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Name="BtnVerifyTab" 
                        Content="✓ Verify" 
                        Click="BtnVerifyTab_Click"
                        Margin="8,4,8,4"
                        Padding="10,12"
                        Background="#3e3e42"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Name="BtnMonitorTab" 
                        Content="👁️ Monitor" 
                        Click="BtnMonitorTab_Click"
                        Margin="8,4,8,4"
                        Padding="10,12"
                        Background="#3e3e42"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Name="BtnSettingsTab" 
                        Content="⚙️ Settings" 
                        Click="BtnSettingsTab_Click"
                        Margin="8,4,8,4"
                        Padding="10,12"
                        Background="#3e3e42"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <!-- Separator -->
                <Rectangle Height="1" Fill="#444447" Margin="8,15"/>

                <!-- Spacer -->
                <StackPanel VerticalAlignment="Stretch" Background="Transparent"></StackPanel>

                <!-- Theme Toggle -->
                <Button Name="BtnThemeToggle" 
                        Content="🌙 Toggle Theme" 
                        Click="BtnThemeToggle_Click"
                        Background="#444447"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Padding="10,12"
                        Margin="8,4,8,8"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <!-- Exit Button -->
                <Button Name="BtnExit" 
                        Content="🚪 Exit" 
                        Click="BtnExit_Click"
                        Background="#FF4455"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Padding="10,12"
                        Margin="8,0,8,8"
                        BorderThickness="0"
                        Cursor="Hand"/>
                
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <TabControl Grid.Column="1"
                    Name="MainTabControl"
                    Background="{DynamicResource BackgroundBrush}"
                    Margin="0">
            
            <!-- Dashboard Tab -->
            <TabItem Header="Dashboard" 
                     x:Name="DashboardTab"
                     IsSelected="True">
                <local:DashboardTab/>
            </TabItem>

            <!-- Main Page Tab -->
            <TabItem Header="Main Page" 
                     x:Name="MainTab">
                <Frame Source="Views/MainTab.xaml" 
                       NavigationUIVisibility="Hidden"/>
            </TabItem>

            <!-- Verify Tab -->
            <TabItem Header="✓ Verify" 
                     x:Name="VerifyTab">
                <local:VerifyTab/>
            </TabItem>

            <!-- Monitor Tab -->
            <TabItem Header="Monitor" 
                     x:Name="MonitorTab">
                <Frame Source="Views/MonitorTab.xaml" 
                       NavigationUIVisibility="Hidden"/>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings" 
                     x:Name="SettingsTab">
                <Frame Source="Views/SettingsTab.xaml" 
                       NavigationUIVisibility="Hidden"/>
            </TabItem>

        </TabControl>

    </Grid>

</Window>
